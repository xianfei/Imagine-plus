{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImaginePlus",
  "version": "0.10.1",
  "identifier": "com.meowtec.imagine.plus",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:9999",
    "beforeBuildCommand": "npm run vite:build",
    "frontendDist": "../dist/web"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": false,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/imagine/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "GraphicsAndDesign",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["png", "jpg", "jpeg"],
        "role": "Editor",
        "description": "Images"
      }
    ]
  }
}
